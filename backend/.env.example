DEBUG=true
DATABASE_URL=sqlite:///./data/careerops.db

# LLM provider keys (optional — only needed once Milestone 3 wires up real providers)
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Job provider keys (optional — providers work without these but return
# empty results until configured; register for free at each provider's site)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Embedding provider for semantic search (Milestone 5). Defaults to the
# free local "hashing" provider (no key needed) if left blank; set
# EMBEDDING_DEFAULT_PROVIDER=voyage and configure this key for real neural
# embeddings with better cross-terminology matching.
VOYAGE_API_KEY=
